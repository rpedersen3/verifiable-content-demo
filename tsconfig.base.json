{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "baseUrl": ".",
    "paths": {
      "@agenticprimitives/types": ["packages/types/src/index.ts"],
      "@agenticprimitives/audit": ["packages/audit/src/index.ts"],
      "@agenticprimitives/connect-auth": ["packages/connect-auth/src/index.ts"],
      "@agenticprimitives/connect-auth/passkey": ["packages/connect-auth/src/methods/passkey.ts"],
      "@agenticprimitives/connect-auth/siwe": ["packages/connect-auth/src/methods/siwe.ts"],
      "@agenticprimitives/connect-auth/google": ["packages/connect-auth/src/methods/google.ts"],
      "@agenticprimitives/agent-account": ["packages/agent-account/src/index.ts"],
      "@agenticprimitives/delegation": ["packages/delegation/src/index.ts"],
      "@agenticprimitives/related-agents": ["packages/related-agents/src/index.ts"],
      "@agenticprimitives/key-custody": ["packages/key-custody/src/index.ts"],
      "@agenticprimitives/key-custody/local": ["packages/key-custody/src/providers/local.ts"],
      "@agenticprimitives/key-custody/aws": ["packages/key-custody/src/providers/aws.ts"],
      "@agenticprimitives/key-custody/gcp": ["packages/key-custody/src/providers/gcp.ts"],
      "@agenticprimitives/tool-policy": ["packages/tool-policy/src/index.ts"],
      "@agenticprimitives/mcp-runtime": ["packages/mcp-runtime/src/index.ts"],
      "@agenticprimitives/ontology": ["packages/ontology/src/index.ts"],
      "@agenticprimitives/ontology/artifacts": ["packages/ontology/src/artifacts.ts"],
      "@agenticprimitives/identity-directory": ["packages/identity-directory/src/index.ts"],
      "@agenticprimitives/identity-directory-adapters": ["packages/identity-directory-adapters/src/index.ts"],
      "@agenticprimitives/connect": ["packages/connect/src/index.ts"],
      "@agenticprimitives/verifiable-credentials": ["packages/verifiable-credentials/src/index.ts"],
      "@agenticprimitives/attestations": ["packages/attestations/src/index.ts"],
      "@agenticprimitives/agreements": ["packages/agreements/src/index.ts"],
      "@agenticprimitives/intent-marketplace": ["packages/intent-marketplace/src/index.ts"],
      "@agenticprimitives/intent-resolver": ["packages/intent-resolver/src/index.ts"],
      "@agenticprimitives/payments": ["packages/payments/src/index.ts"],
      "@agenticprimitives/fulfillment": ["packages/fulfillment/src/index.ts"]
    }
  }
}
