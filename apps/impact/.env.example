# Impact (Next.js / Vercel) — PLACEHOLDERS ONLY (never commit real values).
# Local dev: copy to .env.local. In Vercel set these under Settings → Environment Variables.

# ── Live agenticprimitives backend (the /a2a and /mcp-bind rewrites) ──────────
# These are the same deployed Workers demo-sso-next uses for real ceremonies.
DEMO_A2A_URL=https://demo-a2a-production.richardpedersen3.workers.dev
DEMO_MCP_URL=https://demo-mcp-production.richardpedersen3.workers.dev

# ── On-chain resolution (Base Sepolia). Use a keyed RPC in prod (Sensitive). ──
RPC_URL=https://sepolia.base.org

# ── Phase-1 demo seed ─────────────────────────────────────────────────────────
# When set, the entry experience signs you straight into the seeded demo identity
# (skips the credential-method picker). Leave unset for the full entry flow.
NEXT_PUBLIC_IMPACT_DEMO_AUTOLOGIN=
