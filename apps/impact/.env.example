# Impact (Next.js / Vercel) — PLACEHOLDERS ONLY (never commit real values).
# Local dev: copy to .env.local. In Vercel set these under Settings → Environment Variables.

# ── Live agenticprimitives backend (the /a2a and /mcp-bind rewrites) ──────────
# Same deployed Workers demo-sso-next uses for real ceremonies (relayer + custody + vault).
DEMO_A2A_URL=https://demo-a2a-production.richardpedersen3.workers.dev
DEMO_MCP_URL=https://demo-mcp-production.richardpedersen3.workers.dev

# ── Broker session-signing key (REQUIRED for passkey + SIWE sign-in) ──────────
# The home mints its own AgentSession JWTs with this ES256 (P-256) key. Generate one:
#   node scripts/gen-broker-key.mjs
# Then set BOTH below (mark BROKER_PRIVATE_JWK as Sensitive). Only the PUBLIC half is
# exposed via GET /jwks. Never commit a populated value.
BROKER_PRIVATE_JWK=<server-side only — generate with scripts/gen-broker-key.mjs>
BROKER_KID=broker-1

# ── KV store (REQUIRED in production) — single-use nonces + passkey challenges ─
# Attach a Vercel KV / Upstash Redis store; it provisions these. Without them, local
# dev falls back to a NON-persistent in-memory store (fine for one dev instance only).
KV_REST_API_URL=https://REPLACE.upstash.io
KV_REST_API_TOKEN=REPLACE

# ── On-chain resolution (Base Sepolia). Use a keyed RPC in prod (Sensitive). ──
RPC_URL=https://sepolia.base.org

# ── Social sign-in (Google / YouVersion) — OPTIONAL; needs YOU to provision ────
# Until these are set, the Google/YouVersion buttons report "needs configuration".
# Google OAuth client (console.cloud.google.com) — redirect URI must match exactly:
GOOGLE_CLIENT_ID=REPLACE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE
GOOGLE_REDIRECT_URI=https://YOUR-DOMAIN/oidc/google/callback
# YouVersion (public PKCE client — no secret). The App Key is defaulted in app/_lib/env.ts
# (cZGdGdSgytOfEmpW05EOaSsD5aApv5SQp16QnuMh57AqbErG); set this only to override it.
YOUVERSION_CLIENT_ID=
YOUVERSION_REDIRECT_URI=https://YOUR-DOMAIN/oidc/youversion/callback
# Custody bridge to demo-a2a (Google/YouVersion derive a KMS-custodied SA server-side).
# A2A_CUSTODY_BRIDGE_SECRET MUST match the value configured in your demo-a2a deployment.
A2A_CUSTODY_URL=https://demo-a2a-production.richardpedersen3.workers.dev
A2A_CUSTODY_BRIDGE_SECRET=REPLACE
