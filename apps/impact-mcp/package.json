{
  "name": "@verifiable-content-demo/impact-mcp",
  "version": "0.0.1",
  "private": true,
  "description": "Impact MCP server: Cloudflare Worker + D1 for profiles + JTI replay. Person-repository with delegation-verified get_profile tool. Copied from agenticprimitives demo-mcp.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8798 --inspector-port 9233 --persist-to ../../.wrangler/state-impact-mcp",
    "deploy": "wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply impact-mcp --local --persist-to ../../.wrangler/state-impact-mcp",
    "d1:migrate:remote": "wrangler d1 migrations apply impact-mcp --remote",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agenticprimitives/agent-naming": "^1.0.0-alpha.13",
    "@agenticprimitives/audit": "^1.0.0-alpha.13",
    "@agenticprimitives/delegation": "^1.0.0-alpha.13",
    "@agenticprimitives/entitlements": "0.0.0-alpha.2",
    "@agenticprimitives/key-authorization": "0.0.0-alpha.3",
    "@agenticprimitives/key-custody": "^1.0.0-alpha.13",
    "@agenticprimitives/mcp-oauth": "0.0.0-alpha.2",
    "@agenticprimitives/mcp-runtime": "^1.0.0-alpha.13",
    "@agenticprimitives/tool-policy": "^1.0.0-alpha.13",
    "@agenticprimitives/types": "^1.0.0-alpha.13",
    "@agenticprimitives/vault": "0.0.0-alpha.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260604.1",
    "@types/node": "^22.7.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
