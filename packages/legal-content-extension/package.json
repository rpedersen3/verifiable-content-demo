    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agenticprimitives/content-primitives": "1.0.0-alpha.14"
  },
  "devDependencies": {
    "@agenticprimitives/verifiable-credentials": "0.0.0-alpha.10",
    "@types/node": "^22.7.0",
    "viem": "^2.52.2",
    "vitest": "^4.1.8"
  }
}
