{
  "name": "@verifiable-content-demo/legal-content-extension",
  "version": "0.1.0",
  "private": true,
  "description": "A SECOND content vertical (US legal code) built on the published @agenticprimitives/content-primitives — proving the substrate is generic, not Bible-specific. No scripture code.",
