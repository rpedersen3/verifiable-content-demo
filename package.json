{
  "name": "verifiable-content-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Example app consuming the published @agenticprimitives/* packages from npm: a BibleGateway-style scripture lookup (web + a2a + mcp) built on @agenticprimitives/content-primitives + scripture-content-extension. Public-domain text only.",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:mcp": "pnpm --filter @verifiable-content-demo/bible-mcp dev",
    "dev:a2a": "pnpm --filter @verifiable-content-demo/bible-a2a dev",
    "dev:web": "pnpm --filter @verifiable-content-demo/bible-web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "smoke": "pnpm exec tsx apps/demo-bible-a2a/smoke.ts",
    "check:no-licensed-content": "tsx scripts/check-no-licensed-content.ts"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.0"
    }
  },
  "packageManager": "pnpm@9.0.0"
}
