{
  "name": "verifiable-content-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Example app consuming the published @agenticprimitives/* packages from npm: a BibleGateway-style scripture lookup (web + a2a + mcp) built on @agenticprimitives/content-primitives + scripture-content-extension. Public-domain text only.",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:mcp": "pnpm --filter @verifiable-content-demo/bible-mcp dev",
    "dev:a2a": "pnpm --filter @verifiable-content-demo/bible-a2a dev",
    "dev:web": "pnpm --filter @verifiable-content-demo/bible-web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "smoke": "pnpm exec tsx apps/demo-bible-a2a/smoke.ts",
    "zk:setup": "pnpm --filter @verifiable-content-demo/zk-membership setup",
    "validator": "pnpm --filter @verifiable-content-demo/validator start",
    "validate:e2e": "tsx scripts/validator-e2e.ts",
    "check:no-licensed-content": "tsx scripts/check-no-licensed-content.ts",
    "kms:apply": "tsx scripts/kms-apply.ts",
    "vault:e2e": "tsx scripts/vault-e2e.ts",
    "secrets:impact": "bash scripts/set-impact-secrets.sh",
    "deploy:impact": "tsx scripts/deploy-impact-workers.ts"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@agenticprimitives/verifiable-credentials": "0.0.0-alpha.10",
    "@agenticprimitives/contracts": "1.0.0-alpha.13",
    "@agenticprimitives/ap-kms": "0.0.0-alpha.4",
    "@agenticprimitives/key-custody": "1.0.0-alpha.13",
    "@agenticprimitives/delegation": "1.0.0-alpha.13",
    "@agenticprimitives/agent-naming": "1.0.0-alpha.13",
    "@agenticprimitives/types": "1.0.0-alpha.13",
    "@verifiable-content-demo/zk-membership": "workspace:*",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "viem": "^2.52.2",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.0",
      "@agenticprimitives/a2a": "0.0.0-alpha.9",
      "@agenticprimitives/fulfillment": "0.0.0-alpha.10",
      "@agenticprimitives/delegation": "1.0.0-alpha.13",
      "@agenticprimitives/delegated-signer": "0.0.0-alpha.5",
      "@agenticprimitives/agent-account": "1.0.0-alpha.13",
      "@agenticprimitives/agent-naming": "1.0.0-alpha.13",
      "@agenticprimitives/ap-kms": "0.0.0-alpha.4",
      "@agenticprimitives/audit": "1.0.0-alpha.13",
      "@agenticprimitives/connect": "1.0.0-alpha.13",
      "@agenticprimitives/connect-auth": "1.0.0-alpha.13",
      "@agenticprimitives/content-primitives": "1.0.0-alpha.14",
      "@agenticprimitives/identity-directory": "1.0.0-alpha.13",
      "@agenticprimitives/identity-directory-adapters": "1.0.0-alpha.13",
      "@agenticprimitives/key-custody": "1.0.0-alpha.13",
      "@agenticprimitives/mcp-runtime": "1.0.0-alpha.13",
      "@agenticprimitives/ontology": "1.0.0-alpha.13",
      "@agenticprimitives/related-agents": "0.0.0-alpha.9",
      "@agenticprimitives/tool-policy": "1.0.0-alpha.13",
      "@agenticprimitives/types": "1.0.0-alpha.13",
      "@agenticprimitives/verifiable-credentials": "0.0.0-alpha.10",
      "@agenticprimitives/vault": "0.0.0-alpha.2",
      "@agenticprimitives/entitlements": "0.0.0-alpha.2",
      "@agenticprimitives/key-authorization": "0.0.0-alpha.3",
      "@agenticprimitives/mcp-oauth": "0.0.0-alpha.2",
      "@agenticprimitives/payments": "0.0.0-alpha.9"
    }
  },
  "packageManager": "pnpm@9.0.0"
}
